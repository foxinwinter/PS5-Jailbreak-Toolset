                ps5_ip, ps5_port = self.ask_ps5_config()
            else:
                ps5_ip, ps5_port = self.read_ps5_config()
                if ps5_ip is None or ps5_port is None:
                    ps5_ip, ps5_port = self.ask_ps5_config()

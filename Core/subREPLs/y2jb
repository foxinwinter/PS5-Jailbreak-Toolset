ESCAPE_SEQUENCE_RE = re.compile(r'\x1b\[[0-9;]*[a-zA-Z]')

def sanitize_log(message):
    return ESCAPE_SEQUENCE_RE.sub('', message)

def compute_sha256(file_path):
    sha256_hash = hashlib.sha256()
    with open(file_path, "rb") as f:
        for byte_block in iter(lambda: f.read(4096), b""):
            sha256_hash.update(byte_block)
    return sha256_hash.hexdigest()

def verify_tool_hashes():
    import os
    verification_dir = os.path.join(BASE_DIR, "Core", "Verification", "HashVerification")
    hashes_file = os.path.join(verification_dir, "hashes", "hashes.txt")
    if not os.path.exists(hashes_file):
        print("[WARNING] No hashes.txt found - skipping tool verification")
        return True
    
    trusted = {}
    with open(hashes_file, "r") as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            if ":" in line:
                name, hash_val = line.split(":", 1)
                name = name.strip().upper()
                hash_val = hash_val.strip()
                if name.startswith("TOOL_Y2JB_"):
                    trusted[name] = hash_val
    
    tools = {
        "TOOL_Y2JB_PAYLOAD_SENDER": PAYLOAD_SENDER,
        "TOOL_Y2JB_LOG_SERVER": LOG_SERVER,
    }
    
    print("Tool Integrity Check")
    print("-" * 60)
    
    all_valid = True
    for tool_name, tool_path in tools.items():
        expected_hash = trusted.get(tool_name)
        if not expected_hash:
            print(f"[WARN] {tool_name:<30} no hash configured")
            continue
        if not os.path.exists(tool_path):
            print(f"[ERR ] {tool_name:<30} tool not found")
            all_valid = False
            continue
        actual_hash = compute_sha256(tool_path)
        if actual_hash == expected_hash:
            print(f"[ OK ] {tool_name:<30} {actual_hash[:16]}...")
        else:
            print(f"[ERR ] {tool_name:<30} mismatch!")
            all_valid = False
    
    return all_valid

def verify_payload_signature():
    try:
        from cryptography.hazmat.primitives.asymmetric import padding
        from cryptography.hazmat.primitives import hashes, serialization
        from cryptography.hazmat.backends import default_backend
    except ImportError:
        print("[WARNING] cryptography not installed - skipping payload signature verification")
        return True

    verification_dir = os.path.join(BASE_DIR, "Core", "Verification", "HashVerification")
    public_key_path = os.path.join(verification_dir, "private", "public_key.pem")
    hashes_file = os.path.join(verification_dir, "hashes", "hashes.txt")
    signature_file = os.path.join(verification_dir, "hashes", "hashes.sig")

    if not os.path.exists(public_key_path):
        print("[WARNING] public_key.pem not found - skipping payload signature verification")
        return True
    if not os.path.exists(signature_file):
        print("[WARNING] hashes.sig not found - skipping payload signature verification")
        return True

    try:
        with open(public_key_path, "rb") as f:
            public_key = serialization.load_pem_public_key(f.read(), backend=default_backend())
        with open(hashes_file, "rb") as f:
            data = f.read()
        with open(signature_file, "rb") as f:
            signature = f.read()
        public_key.verify(signature, data, padding.PKCS1v15(), hashes.SHA256())
        return True
    except Exception as e:
        print(f"[SECURITY] Payload signature verification FAILED: {e}")
        return False

def verify_payload_hashes():
    verification_dir = os.path.join(BASE_DIR, "Core", "Verification", "HashVerification")
    hashes_file = os.path.join(verification_dir, "hashes", "hashes.txt")
    if not os.path.exists(hashes_file):
        print("[ERROR] hashes.txt not found!")
        return False
    
    trusted = {}
    with open(hashes_file, "r") as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            if ":" in line:
                name, hash_val = line.split(":", 1)
                name = name.strip().upper()
                hash_val = hash_val.strip()
                if name.startswith("PAYLOAD_Y2JB_") or name.startswith("PAYLOAD_JS_"):
                    trusted[name] = hash_val
    
    payloads = {
        "PAYLOAD_Y2JB_DLSYM_TEST": DLSYM_TEST_JS,
        "PAYLOAD_Y2JB_LAPSE": LAPSE_JS,
        "PAYLOAD_Y2JB_SETLOGSERVER": SETLOGSERVER_JS,
        "PAYLOAD_Y2JB_PS5_HEURISTIC": PS5_HEURISTIC_JS,
    }
    
    def get_hash(name):
        name_part = "_".join(name.split("_")[2:])
        for prefix in ["PAYLOAD_Y2JB_", "PAYLOAD_JS_"]:
            h = trusted.get(prefix + name_part)
            if h:
                return h
        return None
    
    print("Payload Integrity Check")
    print("-" * 60)
    
    all_valid = True
    for payload_name, payload_path in payloads.items():
        expected_hash = get_hash(payload_name)
        if not expected_hash:
            print(f"[WARN] {payload_name:<30} no hash configured")
            continue
        if not os.path.exists(payload_path):
            print(f"[ERR ] {payload_name:<30} not found")
            all_valid = False
            continue
        actual_hash = compute_sha256(payload_path)
        if actual_hash == expected_hash:
            print(f"[ OK ] {payload_name:<30} {actual_hash[:16]}...")
        else:
            print(f"[ERR ] {payload_name:<30} mismatch!")
            all_valid = False
    
    print()
    return all_valid


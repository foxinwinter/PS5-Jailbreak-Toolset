        print("\nWaiting for PS5 to respond with FW_VERSION...")
        fw_version = self.wait_for_fw_version()

        if fw_version is None:
            print("ERROR: Timeout waiting for FW_VERSION from PS5")
            proc.terminate()
            return

        print(f"Detected FW_VERSION: {fw_version}")

        fw_num = self.parse_fw_version(fw_version)
        if fw_num > 1001:
            print("\nlapse.js cannot be run on FW Versions higher than 10.01")
            print("Stopping here.")
            proc.terminate()
            return

        print("\nSending dlsym_test.js to check jailbreak status...")
        self.send_payload(DLSYM_TEST_JS, ps5_ip, ps5_port)

        time.sleep(2)

        is_jailbroken = self.check_jailbroken()

        if is_jailbroken:
            print("\nPS5 is already jailbroken! Entering Y2JB console...")
            self.y2jb_repl(ps5_ip, ps5_port)
            proc.terminate()
            return

        print("\nPS5 is not jailbroken. Sending lapse.js...")
        print(f"\nSending lapse.js to {ps5_ip}:{ps5_port}...")
        self.send_payload(LAPSE_JS, ps5_ip, ps5_port)

        print("\n=== All payloads sent successfully ===")
        proc.terminate()


        try:
            from Core.Exploits.Y2JB.SubREPL.jailbroken import repl as jailbroken_repl

            jailbroken_repl(ps5_ip, ps5_port)
        except ImportError:
            print("Error: jailbroken.py not found")
            print(f"Expected: {os.path.join(SCRIPT_DIR, 'SubREPL', 'jailbroken.py')}")


